rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: shared_frames
    // Document ID: {frameId}
    // Fields:
    //   - uid: string (required) - immutable
    //   - imageData: string (required) - immutable
    //   - createdAt: timestamp (required) - immutable
    //
    // ===============================================================
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }

    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
       return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
       return !('uid' in request.resource.data) ||
         request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
       return !('uid' in request.resource.data) ||
         request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }
    
    // Domain Validator
    function isValidSharedFrame(data) {
      return hasOnlyAllowedFields(['uid', 'imageData', 'createdAt']) &&
             data.uid is string &&
             data.imageData is string && data.imageData.size() > 0 && data.imageData.size() < 1048576 && // Less than 1MB
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /shared_frames/{frameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isValidSharedFrame(request.resource.data) && 
                    uidUnchanged();
      allow update: if isAuthenticated() && 
                    isValidSharedFrame(request.resource.data) && 
                    isDocOwner() &&
                    uidNotModified() &&
                    areImmutableFieldsUnchanged(['uid', 'imageData', 'createdAt']);
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
