rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas optimizadas para FrameIt
    match /shared_frames/{doc} {
      // 1. Los invitados pueden ver los marcos sin necesidad de login
      allow read: if true;
      
      // 2. Solo tú puedes crear y editar marcos
      // Usamos el correo que vimos en el error de consola para darte permiso total
      allow write: if request.auth != null && 
                   (request.auth.token.email == 'frameit@frameit.com' ||
                    request.auth.token.email == 'rauldrt5@gmail.com');
    }

    // Catch-all de seguridad para el resto de la base de datos
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == 'rauldrt5@gmail.com';
    }
  }
}
